{
  "buildCommand": "prisma generate && next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXTAUTH_URL": {
      "description": "Production URL for NextAuth"
    },
    "NEXTAUTH_SECRET": {
      "description": "Secret for NextAuth JWT encryption - generate with: openssl rand -base64 32"
    }
  }
}
